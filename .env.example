# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos)
GITHUB_TOKEN=

# Anthropic API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Linear API Key
# Create at: https://linear.app/settings/api
LINEAR_API_KEY=

# Linear Team ID
# Find by going to your team settings in Linear
# The URL will be like: https://linear.app/your-org/settings/teams/YOUR-TEAM-ID
LINEAR_TEAM_ID=

# Target repository to scan
# Format: owner/repo (e.g., "mehdielamine/theundercut")
TARGET_REPO=mehdielamine/theundercut

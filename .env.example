# =================================
# Clerk Authentication
# =================================
# Get from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# =================================
# Supabase Database
# =================================
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# =================================
# GitHub OAuth (for user connections)
# =================================
# Create at: https://github.com/settings/developers
# Callback URL: https://yourapp.com/api/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=xxx
GITHUB_OAUTH_CLIENT_SECRET=xxx

# =================================
# Linear OAuth (for user connections)
# =================================
# Create at: https://linear.app/settings/api/applications
# Callback URL: https://yourapp.com/api/oauth/linear/callback
LINEAR_OAUTH_CLIENT_ID=xxx
LINEAR_OAUTH_CLIENT_SECRET=xxx

# =================================
# Anthropic (shared for AI analysis)
# =================================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# =================================
# Token Encryption
# =================================
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# =================================
# App Configuration
# =================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =================================
# DEPRECATED - These are replaced by OAuth
# =================================
# GITHUB_TOKEN        # -> per-user OAuth
# LINEAR_API_KEY      # -> per-user OAuth
# LINEAR_TEAM_ID      # -> per-workspace setting
# TARGET_REPO         # -> repositories table
